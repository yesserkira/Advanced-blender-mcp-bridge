{
  // VS Code MCP configuration for Blender MCP Bridge.
  // Place this file at .vscode/mcp.json in your project root.
  //
  // If installed via pipx:  "command": "pipx run blender-mcp"
  // If installed via uv:    "command": "uv run blender-mcp"
  // If installed locally:   "command": "blender-mcp"
  "servers": {
    "blender": {
      "command": "blender-mcp",
      "args": [],
      "env": {
        "BLENDER_MCP_TOKEN": "${input:blender_token}"
      }
    }
  },
  "inputs": [
    {
      "id": "blender_token",
      "type": "promptString",
      "description": "Blender MCP auth token (copy from Blender N-panel > MCP tab)",
      "password": true
    }
  ]
}