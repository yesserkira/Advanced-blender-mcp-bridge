{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://blendermcp.local/schemas/geonodes.schema.json",
  "title": "BlenderMCP Geometry Nodes DSL",
  "description": "Schema for geonodes.build args and response.",
  "definitions": {
    "node_definition": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this node (used in links)."
        },
        "type": {
          "type": "string",
          "description": "Blender node type string, e.g. 'GeometryNodeMeshCube'."
        },
        "label": {
          "type": [
            "string",
            "null"
          ],
          "description": "Optional display label."
        },
        "location": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "Node position [x, y]. Auto-layout if omitted."
        },
        "inputs": {
          "type": "object",
          "description": "Input socket defaults (socket_name → value).",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "link_definition": {
      "type": "object",
      "required": [
        "from_node",
        "from_socket",
        "to_node",
        "to_socket"
      ],
      "properties": {
        "from_node": {
          "type": "string",
          "description": "ID of source node. Use 'group_input' for GroupInput."
        },
        "from_socket": {
          "type": "string",
          "description": "Output socket name on the source node."
        },
        "to_node": {
          "type": "string",
          "description": "ID of target node. Use 'group_output' for GroupOutput."
        },
        "to_socket": {
          "type": "string",
          "description": "Input socket name on the target node."
        }
      },
      "additionalProperties": false
    },
    "socket_definition": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Socket display name."
        },
        "type": {
          "type": "string",
          "description": "Socket type, e.g. 'NodeSocketFloat', 'NodeSocketVector', 'NodeSocketGeometry'."
        }
      },
      "additionalProperties": false
    },
    "build_args": {
      "type": "object",
      "required": [
        "object_name",
        "nodes"
      ],
      "properties": {
        "object_name": {
          "type": "string",
          "description": "Target mesh object name."
        },
        "modifier_name": {
          "type": "string",
          "default": "AI_GeoNodes",
          "description": "Display name for the modifier."
        },
        "group_name": {
          "type": "string",
          "description": "Name for the node group. Defaults to modifier_name."
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/node_definition"
          },
          "description": "List of node definitions."
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/link_definition"
          },
          "description": "List of node connections."
        },
        "group_inputs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/socket_definition"
          },
          "description": "Optional group interface input sockets."
        },
        "group_outputs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/socket_definition"
          },
          "description": "Optional group interface output sockets."
        }
      },
      "additionalProperties": false
    },
    "build_response": {
      "type": "object",
      "required": [
        "object",
        "modifier",
        "node_count",
        "link_count"
      ],
      "properties": {
        "object": {
          "type": "string",
          "description": "Object name."
        },
        "modifier": {
          "type": "string",
          "description": "Modifier name."
        },
        "node_count": {
          "type": "integer",
          "description": "Total node count (including GroupInput/Output)."
        },
        "link_count": {
          "type": "integer",
          "description": "Total link count."
        }
      },
      "additionalProperties": false
    }
  }
}