{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://blendermcp.local/schemas/response.schema.json",
  "title": "BlenderMCP Response",
  "description": "A response sent from the Blender add-on back to the MCP server.",
  "type": "object",
  "required": ["id", "ok"],
  "properties": {
    "id": {
      "type": ["string", "null"],
      "description": "Matching command identifier."
    },
    "ok": {
      "type": "boolean",
      "description": "True if the command succeeded."
    },
    "result": {
      "description": "Operation result (present when ok=true). Type varies per operation."
    },
    "error": {
      "type": "object",
      "description": "Error details (present when ok=false).",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Error code.",
          "enum": [
            "BAD_FRAME",
            "AUTH",
            "BAD_ARGS",
            "NOT_FOUND",
            "MAIN_THREAD_TIMEOUT",
            "POLICY_DENIED",
            "BLENDER_ERROR",
            "PYTHON_EXEC_ERROR",
            "CHECKPOINT_FAILED",
            "RATE_LIMITED",
            "PATH_DENIED",
            "RESOURCE_CAP",
            "SERVER_STOPPED"
          ]
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message."
        },
        "traceback": {
          "type": "string",
          "description": "Python traceback (only for BLENDER_ERROR / PYTHON_EXEC_ERROR)."
        },
        "hint": {
          "type": "string",
          "description": "Suggested fix or next step."
        },
        "retry_after_ms": {
          "type": "integer",
          "description": "Milliseconds to wait before retrying (for RATE_LIMITED)."
        }
      },
      "additionalProperties": false
    },
    "elapsed_ms": {
      "type": "integer",
      "description": "Wall-clock time in milliseconds for the command."
    },
    "undo_id": {
      "type": "string",
      "description": "Undo checkpoint identifier for mutating operations."
    },
    "event": {
      "type": "string",
      "description": "Event type for streaming messages.",
      "enum": ["progress", "log"]
    },
    "pct": {
      "type": "number",
      "description": "Progress percentage (0-100) for 'progress' events.",
      "minimum": 0,
      "maximum": 100
    }
  },
  "additionalProperties": false
}
