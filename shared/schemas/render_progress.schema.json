{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://blendermcp.local/schemas/render_progress.schema.json",
  "title": "BlenderMCP Render Progress",
  "description": "Progress frame sent during viewport_screenshot rendering.",
  "type": "object",
  "required": [
    "id",
    "type",
    "progress"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Command ID this progress relates to.",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "const": "progress",
      "description": "Frame type identifier."
    },
    "progress": {
      "type": "object",
      "required": [
        "percent",
        "message"
      ],
      "properties": {
        "percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Progress percentage (0-100)."
        },
        "message": {
          "type": "string",
          "description": "Human-readable progress message."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}