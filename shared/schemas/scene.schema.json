{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://blendermcp.local/schemas/scene.schema.json",
  "title": "BlenderMCP Scene Info",
  "description": "Scene information returned by scene.get at various detail levels.",
  "type": "object",
  "required": ["scene", "frame"],
  "properties": {
    "scene": {
      "type": "string",
      "description": "Scene name."
    },
    "frame": {
      "type": "object",
      "required": ["current", "start", "end", "fps"],
      "properties": {
        "current": { "type": "integer" },
        "start": { "type": "integer" },
        "end": { "type": "integer" },
        "fps": { "type": "number" }
      },
      "additionalProperties": false
    },
    "object_counts": {
      "type": "object",
      "description": "Count of objects per type (summary+).",
      "additionalProperties": { "type": "integer" }
    },
    "active_camera": {
      "type": ["string", "null"],
      "description": "Name of the active camera."
    },
    "selection": {
      "type": "array",
      "description": "Names of selected objects (standard+).",
      "items": { "type": "string" }
    },
    "active": {
      "type": ["string", "null"],
      "description": "Name of the active object (standard+)."
    },
    "objects": {
      "type": "array",
      "description": "Per-object details (standard+).",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["MESH", "CURVE", "SURFACE", "META", "FONT", "CURVES",
                     "POINTCLOUD", "VOLUME", "GREASEPENCIL", "GPENCIL",
                     "ARMATURE", "LATTICE", "EMPTY", "LIGHT", "LIGHT_PROBE",
                     "CAMERA", "SPEAKER"]
          },
          "location": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "rotation_euler": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "scale": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "dimensions": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "parent": {
            "type": ["string", "null"]
          },
          "collection": {
            "type": "string"
          },
          "mesh": {
            "type": "object",
            "description": "Mesh stats (full detail only).",
            "properties": {
              "vertices": { "type": "integer" },
              "edges": { "type": "integer" },
              "polygons": { "type": "integer" },
              "materials": {
                "type": "array",
                "items": { "type": ["string", "null"] }
              }
            },
            "additionalProperties": false
          },
          "modifiers": {
            "type": "array",
            "description": "Modifier list (full detail only).",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "animation": {
            "type": "object",
            "description": "Animation summary (full detail only).",
            "properties": {
              "has_action": { "type": "boolean" },
              "action_name": { "type": ["string", "null"] },
              "keyframe_count": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "collections": {
      "type": "array",
      "description": "Collection hierarchy (standard+).",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "children": {
            "type": "array",
            "items": { "type": "string" }
          },
          "objects": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "world": {
      "type": "object",
      "description": "World info (standard+).",
      "properties": {
        "name": { "type": ["string", "null"] },
        "use_nodes": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
