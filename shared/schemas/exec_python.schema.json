{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://blendermcp.local/schemas/exec_python.schema.json",
  "title": "BlenderMCP Execute Python",
  "description": "Schema for the exec.python operation (AST-validated code execution).",
  "definitions": {
    "exec_python_args": {
      "type": "object",
      "required": [
        "code"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Python source code to execute. Must pass AST validation.",
          "minLength": 1
        },
        "timeout": {
          "type": "number",
          "description": "Maximum execution time in seconds. Default 10, max 30.",
          "default": 10,
          "minimum": 0,
          "maximum": 30
        }
      },
      "additionalProperties": false
    },
    "exec_python_result_success": {
      "type": "object",
      "required": [
        "executed",
        "lines"
      ],
      "properties": {
        "executed": {
          "type": "boolean",
          "const": true
        },
        "lines": {
          "type": "integer",
          "description": "Number of lines in the executed code."
        }
      },
      "additionalProperties": false
    },
    "exec_python_result_failure": {
      "type": "object",
      "required": [
        "executed",
        "error",
        "traceback"
      ],
      "properties": {
        "executed": {
          "type": "boolean",
          "const": false
        },
        "error": {
          "type": "string",
          "description": "Error message from the execution."
        },
        "traceback": {
          "type": "string",
          "description": "Full Python traceback."
        }
      },
      "additionalProperties": false
    },
    "exec_python_result": {
      "oneOf": [
        {
          "$ref": "#/definitions/exec_python_result_success"
        },
        {
          "$ref": "#/definitions/exec_python_result_failure"
        }
      ]
    }
  }
}